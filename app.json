{
  "expo": {
    "name": "MyHomeworkPal",
    "slug": "myhomeworkpal-app",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "myhomeworkpal",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myhomeworkpal.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MyHomeworkPal needs camera access to upload photos of assignments.",
        "NSPhotoLibraryUsageDescription": "MyHomeworkPal needs photo library access to upload assignment files."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.myhomeworkpal.app",
      "versionCode": 1,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      },
      "apiUrl": "https://myhomeworkpal-api-production.up.railway.app"
    }
  }
}
